<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Cruzamento de Chaves NF-e e CT-e</title>
  <style>
    body { font-family: Arial, sans-serif; padding: 20px; background-color: #121212; color: #f1f1f1; }
    input { margin-bottom: 10px; display: block; }
    button { margin-top: 10px; padding: 10px 20px; cursor: pointer; background-color: #333; color: #fff; border: none; border-radius: 4px; }

  </style>
</head>
<body>
  <h1>Cruzar Chaves entre CT-e e NF-e (Modelo 55)</h1>
  <label>Selecionar arquivos CT-e (.xml):</label>
  <input type="file" id="cteFiles" multiple accept=".xml">

  <label>Selecionar arquivos NF-e Modelo 55 (.xml):</label>
  <input type="file" id="nfeFiles" multiple accept=".xml">

  <button onclick="cruzarChaves()">Cruzar Informações</button>
  <button onclick="exportarCSV()" id="btnExport" style="display:none">Exportar Resultado em CSV</button>


  <script>
    let dadosExportacao = [];
    let nfeChaves = new Map();
    let empresaNome = '';
    let empresaCNPJ = '';

    async function parseFiles(files) {
      const parser = new DOMParser();
      let data = [];

      for (let file of files) {
        const content = await file.text();
        const xml = parser.parseFromString(content, 'text/xml');
        data.push(xml);
      }

      return data;
    }

    function formatCNPJ(cnpj) {
      return cnpj.replace(/^(\d{2})(\d{3})(\d{3})(\d{4})(\d{2})$/, "$1.$2.$3/$4-$5");
    }

    async function cruzarChaves() {
      const cteFiles = document.getElementById('cteFiles').files;
      const nfeFiles = document.getElementById('nfeFiles').files;

      const ctes = await parseFiles(cteFiles);
      const nfes = await parseFiles(nfeFiles);

      if (nfes.length > 0) {
        const primeira = nfes[0];
        empresaNome = primeira.querySelector('dest > xNome')?.textContent || '';
        const cnpjRaw = primeira.querySelector('dest > CNPJ')?.textContent || '';
        empresaCNPJ = formatCNPJ(cnpjRaw);
      }

      // Mapeia NF-e por chave
      for (let xml of nfes) {
        const chave = xml.querySelector('infNFe')?.getAttribute('Id')?.replace('NFe', '');
        const numero = xml.querySelector('ide > nNF')?.textContent;
        const emitente = xml.querySelector('emit > xNome')?.textContent;
        const valor = xml.querySelector('total > ICMSTot > vNF')?.textContent;

        if (chave) {
          nfeChaves.set(chave, {
            numero,
            emitente,
            valor: parseFloat(valor) || 0
          });
        }
      }

      let resultados = [];

      for (let xml of ctes) {
        const numeroCTe = xml.querySelector('ide > nCT')?.textContent;
        const chaveCTe = xml.querySelector('infCte')?.getAttribute('Id')?.replace('CTe', '');
        const valorCTe = parseFloat(xml.querySelector('vPrest > vTPrest')?.textContent) || 0;

        const chaveRefs = xml.querySelectorAll('infCte > infCTeNorm > infDoc > infNFe > chave');

        for (let chave of chaveRefs) {
          const valorChave = chave.textContent;
          if (nfeChaves.has(valorChave)) {
            const nfe = nfeChaves.get(valorChave);
            resultados.push({
              numeroCTe,
              chaveCTe,
              valorCTe,
              chaveNFe: valorChave,
              numeroNFe: nfe.numero,
              emitente: nfe.emitente,
              valorNFe: nfe.valor
            });
          }
        }
      }
      dadosExportacao = resultados;
      document.getElementById('btnExport').style.display = 'inline-block';

      gerarResultadoHTML(resultados);
    }

    function gerarResultadoHTML(resultados) {
      let totalCTe = 0;
      let totalNFe = 0;

      let html = `
        <!DOCTYPE html>
        <html lang="pt-br">
        <head>
          <meta charset="UTF-8">
          <title>Resultado do Cruzamento:</title>
          <style>
            body { font-family: Arial, sans-serif; padding: 20px; background-color: #121212; color: #f1f1f1;}
            table { width: 100%; border-collapse: collapse; margin-top: 20px; }
            th, td { border: 1px solid #ccc; padding: 8px; text-align: left; }
            th { background-color: #222; }
            tfoot { font-weight: bold; background-color: #1a1a1a; }
          </style>
        </head>
        <body>
          <h1>Resultado do Cruzamento:</h1>
          <p><strong>Nome da Empresa:</strong> ${empresaNome}</p>
          <p><strong>CNPJ:</strong> ${empresaCNPJ}</p>

          <table>
            <thead>
              <tr>
                <th>Número do CT-e</th>
                <th>Chave do CT-e</th>
                <th>Valor do CT-e</th>
                <th>Chave da NF-e</th>
                <th>Número da NF-e</th>
                <th>Emitente</th>
                <th>Valor da Nota NF-e</th>
              </tr>
            </thead>
            <tbody>`;

      resultados.forEach(r => {
        totalCTe += r.valorCTe;
        totalNFe += r.valorNFe;

        html += `
              <tr>
                <td>${r.numeroCTe}</td>
                <td>${r.chaveCTe}</td>
                <td>${r.valorCTe.toFixed(2)}</td>
                <td>${r.chaveNFe}</td>
                <td>${r.numeroNFe}</td>
                <td>${r.emitente}</td>
                <td>${r.valorNFe.toFixed(2)}</td>
              </tr>`;
      });

      html += `
            </tbody>
            <tfoot>
              <tr>
                <td colspan="2"><strong>Totais</strong></td>
                <td><strong>${totalCTe.toFixed(2)}</strong></td>
                <td colspan="3"></td>
                <td><strong>${totalNFe.toFixed(2)}</strong></td>
              </tr>
            </tfoot>
          </table>
        </body>
        </html>`;

      const blob = new Blob([html], { type: 'text/html' });
      const url = URL.createObjectURL(blob);
      window.open(url, '_blank');
    }
    function exportarCSV() {
  if (dadosExportacao.length === 0) {
    alert("Nenhum dado disponível para exportação.");
    return;
  }

  let csv = "Número do CT-e;Chave do CT-e;Valor do CT-e;Chave da NF-e;Número da NF-e;Emitente;Valor da Nota NF-e\n";
  dadosExportacao.forEach(r => {
    csv += `${r.numeroCTe};${r.chaveCTe};${r.valorCTe.toFixed(2)};${r.chaveNFe};${r.numeroNFe};"${r.emitente}";${r.valorNFe.toFixed(2)}\n`;
  });

  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const link = document.createElement("a");
  link.setAttribute("href", url);
  link.setAttribute("download", "resultado_cruzamento.csv");
  link.style.display = "none";
  document.body.appendChild(link);
  link.click();
  document.body.removeChild(link);
}

  </script>

  <footer>
    By. Yudi - Versão 1.1
  </footer>
</body>
</html>
